# Task Manager — Environment Variables
# Copy to .env and fill in

# Required: JWT signing secret (min 32 chars)
AGENTIC_AUTH_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Optional: PostgreSQL connection (if not using SQLite)
# AGENTIC_DATABASE_URL=postgres://user:password@localhost:5432/taskmanager

# Optional: override Bedrock region/profile
# AGENTIC_LLM_BEDROCK_REGION=eu-central-1
# AGENTIC_LLM_BEDROCK_PROFILE=bedrock
