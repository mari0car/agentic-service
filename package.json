{
  "name": "agentic-service",
  "version": "0.1.0",
  "description": "Business logic without code. Backends defined in plain language.",
  "type": "module",
  "bin": {
    "agentic-service": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/lib.js",
    "./lib": "./dist/lib.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "serve": "tsx src/index.ts serve",
    "migrate": "tsx src/index.ts migrate",
    "validate": "tsx src/index.ts validate",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test:e2e": "cd projects/task-manager && ./test-e2e.sh",
    "management": "pnpm --filter agentic-service-management dev",
    "management:build": "pnpm --filter agentic-service-management build",
    "management:server": "pnpm --filter agentic-service-management dev:server",
    "check-port": "./check-port.sh"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.69",
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/openai": "^1.3.22",
    "@aws-sdk/credential-providers": "^3.830.0",
    "@hono/node-server": "^1.14.0",
    "ai": "^6.0.105",
    "ajv": "^8.17.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.5.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.10",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
