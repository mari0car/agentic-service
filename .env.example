# Agentic Service environment variables
# Copy to .env and fill in values

# --- LLM (required) ---
# For AWS Bedrock, set the profile and region in config.yaml (no API key needed)
# For OpenAI: AGENTIC_LLM_API_KEY=sk-...
# AGENTIC_LLM_API_KEY=

# --- Database (required) ---
# PostgreSQL:
# AGENTIC_DATABASE_URL=postgres://user:password@localhost:5432/dbname
# SQLite:
# AGENTIC_DATABASE_URL=file:./data.db

# --- Auth ---
# AGENTIC_AUTH_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars-long

# --- Admin API ---
# AGENTIC_AUTH_ADMIN_API_KEY=your-admin-key

# --- Server ---
# AGENTIC_SERVER_PORT=8080
