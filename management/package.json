{
  "name": "agentic-service-management",
  "version": "0.1.0",
  "private": true,
  "description": "Management UI for Agentic Service projects",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,ui -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:ui": "vite",
    "build": "vite build && tsc --noEmit",
    "preview": "tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.69",
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/openai": "^1.3.22",
    "@aws-sdk/credential-providers": "^3.830.0",
    "@hono/node-server": "^1.14.0",
    "ai": "^6.0.105",
    "dotenv": "^16.5.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.10",
    "js-yaml": "^4.1.0",
    "pino": "^9.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "@tanstack/react-query": "^5.80.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.4",
    "tailwindcss": "^4.1.8",
    "@tailwindcss/vite": "^4.1.8",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
